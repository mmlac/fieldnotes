# fieldnotes worker configuration
# Copy to ~/.fieldnotes/config.toml and edit as needed.

[core]
data_dir = "~/.fieldnotes/data"
log_level = "info"

[neo4j]
uri = "bolt://localhost:7687"
# user and password can also be set via NEO4J_USER / NEO4J_PASSWORD env vars
user = "neo4j"
password = ""

[qdrant]
host = "localhost"
port = 6333
collection = "fieldnotes"
vector_size = 768                 # must match your embedding model

# --- Model Providers ---
# Configure at least one provider. Ollama runs locally with no API key.

[modelproviders.ollama]
type = "ollama"
base_url = "http://localhost:11434"

# Uncomment to use OpenAI (requires OPENAI_API_KEY env var or api_key below):
# [modelproviders.openai]
# type = "openai"
# api_key = ""

# Uncomment to use Anthropic (requires ANTHROPIC_API_KEY env var or api_key below):
# [modelproviders.anthropic]
# type = "anthropic"
# api_key = ""

# --- Named Models ---
# Bind specific model names to providers.

[models.local_embed]
provider = "ollama"
model = "nomic-embed-text"

[models.local_chat]
provider = "ollama"
model = "llama3.2"

# --- Role Bindings ---
# Which model handles each pipeline stage.

[models.roles]
embed = "local_embed"             # vector embeddings
extract = "local_chat"            # entity/triple extraction
extract_fallback = "local_chat"   # retry on malformed JSON
query = "local_chat"              # NL → Cypher translation
vision = "local_chat"             # image analysis
clustering = "local_chat"         # topic naming
completion = "local_chat"         # ask tool synthesis
rerank = "bge_reranker"           # second-stage cross-encoder for hybrid search

# --- Reranker provider + model ---
# Local in-process cross-encoder via sentence-transformers.  Lazy-loads
# the model on first use; pays roughly 1.5–2 GB RAM once warm.

[modelproviders.local]
type = "sentence_transformers"
device = "auto"                   # auto | cpu | cuda | mps
cache_dir = "~/.fieldnotes/data/models"

[models.bge_reranker]
provider = "local"
model = "BAAI/bge-reranker-v2-m3"

# --- Sources ---

[sources.files]
watch_paths = ["~/Documents"]

[sources.obsidian]
vault_paths = ["~/obsidian-vault"]
# categories_key = "categories"   # frontmatter key for category list (default: "categories")

[sources.repositories]
repo_roots = []
include_patterns = ["README*", "CHANGELOG*", "CONTRIBUTING*", "docs/**/*.md", "*.toml", "ADR/**/*.md"]
exclude_patterns = ["node_modules/", ".git/", "vendor/", "target/", "__pycache__/"]
poll_interval_seconds = 300
max_file_size = 104857600

[sources.omnifocus]
# poll_interval_seconds = 300
# state_path = "~/.fieldnotes/state/omnifocus.json"

# --- Clustering ---

[clustering]
enabled = true
cron = "0 3 * * 0"               # Sunday 3 AM
min_corpus_size = 100

# --- Vision ---

[vision]
enabled = true
concurrency = 2
max_file_size_mb = 20

# --- MCP ---

[mcp]
enabled = true
port = 3456

# --- Metrics ---

[metrics]
pushgateway_url = "http://localhost:9091"
push_interval = 15

# --- Health Check (optional) ---

# [health]
# enabled = false
# port = 9100
# bind = "127.0.0.1"

# --- Reranker ---

[reranker]
enabled = true
top_k_pre = 50          # candidates pulled from vector search before rerank
top_k_post = 10         # results kept after rerank
score_threshold = 0.0   # drop candidates below this score
batch_size = 32         # cross-encoder batch size
