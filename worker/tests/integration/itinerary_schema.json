{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "fieldnotes itinerary --json",
  "description": "Stable schema produced by both the CLI (--json) and the MCP itinerary tool. Asserted by tests/integration/test_itinerary_e2e.py — keep this fixture, worker/cli/itinerary.py and worker/mcp_server.py in sync.",
  "type": "object",
  "required": ["day", "timezone", "events"],
  "properties": {
    "day": {
      "type": "string",
      "description": "Resolved local-day in YYYY-MM-DD form."
    },
    "timezone": {
      "type": "string",
      "description": "IANA timezone key (or string repr) the day was resolved in."
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "event_id",
          "source_id",
          "title",
          "start",
          "end",
          "account",
          "calendar_id",
          "organizer",
          "attendees",
          "location",
          "html_link",
          "linked",
          "next_brief"
        ],
        "properties": {
          "event_id": {"type": "string"},
          "source_id": {"type": "string"},
          "title": {"type": ["string", "null"]},
          "start": {"type": ["string", "null"]},
          "end": {"type": ["string", "null"]},
          "account": {"type": ["string", "null"]},
          "calendar_id": {"type": ["string", "null"]},
          "organizer": {
            "type": ["object", "null"],
            "required": ["name", "email"],
            "properties": {
              "name": {"type": ["string", "null"]},
              "email": {"type": ["string", "null"]}
            }
          },
          "attendees": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "email"],
              "properties": {
                "name": {"type": ["string", "null"]},
                "email": {"type": ["string", "null"]}
              }
            }
          },
          "location": {"type": ["string", "null"]},
          "html_link": {"type": ["string", "null"]},
          "linked": {
            "type": "object",
            "required": ["tasks", "notes", "thread"],
            "properties": {
              "tasks": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["title", "project", "tags", "due", "defer", "flagged", "source_id"]
                }
              },
              "notes": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["source_id", "title", "snippet", "mtime", "attendee_overlap", "score"]
                }
              },
              "thread": {
                "type": ["object", "null"],
                "required": ["kind", "source_id", "title", "last_ts", "last_from"],
                "properties": {
                  "kind": {"type": "string", "enum": ["email", "slack"]},
                  "source_id": {"type": "string"},
                  "title": {"type": "string"},
                  "last_ts": {"type": "string"},
                  "last_from": {"type": ["string", "null"]}
                }
              }
            }
          },
          "next_brief": {
            "type": ["string", "null"],
            "description": "LLM-generated meeting brief; null when --brief is set."
          }
        }
      }
    }
  }
}
