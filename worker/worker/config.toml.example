# fieldnotes worker configuration
# Copy to ~/.fieldnotes/config.toml and edit as needed.

# --- Self-identity ---
# The [me] block tells fieldnotes which Person nodes are *you* across
# Gmail, Calendar, Slack, etc. Used to reconcile self-identity at parse time.
# Emails are canonicalized (e.g. @googlemail.com → @gmail.com).
# 'name' is optional; if multiple sources disagree, the longest non-empty
# display name wins.
# [me]
# emails = ["me@personal.com", "me@work.com"]
# name = "Optional Display Name"

[core]
data_dir = "~/.fieldnotes/data"
log_level = "info"

[neo4j]
uri = "bolt://localhost:7687"
# user and password can also be set via NEO4J_USER / NEO4J_PASSWORD env vars
user = "neo4j"
password = ""

[qdrant]
host = "localhost"
port = 6333
collection = "fieldnotes"
vector_size = 768

# --- Sources ---

[sources.files]
watch_paths = ["~/Documents"]
# index_only_patterns = ["*.iso", "*.dmg"]  # index filename only, skip content

[sources.obsidian]
vault_path = "~/obsidian-vault"
# index_only_patterns = ["attachments/"]    # index filename only, skip content

[sources.repositories]
repo_roots = []
include_patterns = ["README*", "CHANGELOG*", "CONTRIBUTING*", "docs/**/*.md", "*.toml", "ADR/**/*.md"]
exclude_patterns = ["node_modules/", ".git/", "vendor/", "target/", "__pycache__/"]
# index_only_patterns = ["*.lock"]          # index filename only, skip content
poll_interval_seconds = 300
max_file_size = 104857600

[sources.omnifocus]
# enabled = true             # auto-detected on macOS
# poll_interval_seconds = 300
# state_path = "~/.fieldnotes/state/omnifocus.json"

# --- Gmail (multi-account) ---
# One [sources.gmail.<account>] section per Gmail account you want to ingest.
# <account> must match ^[a-z][a-z0-9_-]{0,30}$ (e.g. "personal", "work").
# Reserved names (rejected at parse time): "gmail", "calendar",
# "google_calendar", "slack". These would produce cursor keys
# (``{source}:{account}``) that collide with legacy single-account
# migration state. Adjacent names like "gmail-work" or "mygmail" are fine.
# Multiple accounts may share a client_secrets_path (same OAuth client app).
# Presence of the section means enabled; set enabled = false to keep it
# defined but inactive.
#
# [sources.gmail.personal]
# client_secrets_path = "~/.fieldnotes/gmail_credentials.json"
# poll_interval_seconds = 300
# max_initial_threads = 500
# label_filter = "INBOX"
# # Attachment indexing (per-account):
# download_attachments = false                  # off by default
# attachment_max_size_mb = 25                   # 1..200 inclusive
# attachment_indexable_mimetypes = [
#     "application/pdf",
#     "image/png", "image/jpeg",
#     "text/plain", "text/markdown", "text/csv",
# ]
#
# [sources.gmail.work]
# client_secrets_path = "~/.fieldnotes/gmail_credentials.json"
# poll_interval_seconds = 300
# max_initial_threads = 500
# label_filter = "INBOX"

# --- Google Calendar (multi-account) ---
# Same per-account schema as Gmail. Each account can target multiple
# calendars; "primary" is the user's default calendar.
#
# [sources.google_calendar.personal]
# client_secrets_path = "~/.fieldnotes/gmail_credentials.json"
# poll_interval_seconds = 300
# max_initial_days = 90
# calendar_ids = ["primary"]
# # Attachment indexing (per-account).  Calendar attachments live on
# # Drive, so download_attachments=true also requires the
# # drive.readonly OAuth scope (added at install time).
# download_attachments = false                  # off by default
# attachment_max_size_mb = 25                   # 1..200 inclusive
# attachment_indexable_mimetypes = [
#     "application/pdf",
#     "image/png", "image/jpeg",
#     "text/plain", "text/markdown", "text/csv",
# ]
#
# [sources.google_calendar.work]
# client_secrets_path = "~/.fieldnotes/gmail_credentials.json"
# poll_interval_seconds = 300
# max_initial_days = 90
# calendar_ids = ["primary"]

[sources.slack]
enabled = false
# JSON file with Slack app client_id + client_secret. Required when enabled.
client_secrets_path = "~/.fieldnotes/slack_credentials.json"
poll_interval_seconds = 300
max_initial_days = 90                  # backfill window per conversation
include_channels = []                  # channel names or IDs; [] = all joined channels
exclude_channels = []                  # mutually exclusive with include_channels (warn)
include_dms = true                     # include 1:1 and multi-party DMs
include_archived = false
window_max_tokens = 512                # burst-window upper bound (token count) [128..4096]
window_gap_seconds = 1800              # quiet-gap that closes a window (30 min) [60..86400]
window_overlap_messages = 3            # whole-message overlap between windows [0..10]
# Attachment indexing.  Legacy 'download_files' is still accepted and
# silently aliased to download_attachments; setting both warns.
download_attachments = false           # off by default
attachment_max_size_mb = 25            # 1..200 inclusive
# attachment_indexable_mimetypes = [
#     "application/pdf",
#     "image/png", "image/jpeg",
#     "text/plain", "text/markdown", "text/csv",
# ]

# --- Clustering ---

[clustering]
enabled = true
cron = "0 3 * * 0"
min_corpus_size = 100

# --- Vision ---

[vision]
enabled = true
concurrency = 2

# --- MCP ---

[mcp]
enabled = true
port = 3456

# --- Reranker ---
# Second-stage cross-encoder that re-scores hybrid search candidates
# before they reach the LLM (or you).  Big precision win on `ask` and
# `search`; runs locally via sentence-transformers.  Set enabled = false
# to skip reranking entirely (saves ~1.5 GB RAM and the first-call model
# download).

[reranker]
enabled = true
top_k_pre = 50          # candidates pulled from vector search before rerank
top_k_post = 10         # results kept after rerank
score_threshold = 0.0   # drop candidates below this score
batch_size = 32         # cross-encoder batch size

[modelproviders.local]
type = "sentence_transformers"
device = "auto"                   # auto | cpu | cuda | mps
cache_dir = "~/.fieldnotes/data/models"

[models.bge_reranker]
provider = "local"
model = "BAAI/bge-reranker-v2-m3"

[models.roles]
rerank = "bge_reranker"
