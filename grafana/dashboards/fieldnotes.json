      "title": "Pipeline Latency Percentiles",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(pipeline_total_duration_seconds_bucket{job=\"fieldnotes_worker\"}[$__rate_interval])) by (le))",
          "legendFormat": "p50",
