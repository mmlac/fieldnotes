          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 5 },
      "id": 6,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Neo4j Store Size",
      "type": "stat",
      "targets": [
        {
          "expr": "neo4j_store_bytes{job=\"fieldnotes_worker\"}",
          "legendFormat": "Neo4j",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "semi-dark-purple" },
          "unit": "decbytes",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 5 },
      "id": 20,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Qdrant Store Size",
      "type": "stat",
      "targets": [
        {
          "expr": "qdrant_store_bytes{job=\"fieldnotes_worker\"}",
          "legendFormat": "Qdrant",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "text" },
          "unit": "dtdurations",
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Complete", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 60 },
            { "color": "orange", "value": 3600 },
            { "color": "red", "value": 86400 }
          ] },
          "noValue": "—"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 5 },
      "id": 8,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Initial Sync ETA",
      "type": "stat",
      "targets": [
        {
          "expr": "fieldnotes_initial_sync_eta_seconds{job=\"fieldnotes_worker\"}",
          "legendFormat": "ETA",
          "refId": "A"
        }
