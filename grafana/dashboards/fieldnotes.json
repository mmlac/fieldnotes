      "title": "Pipeline Latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 40, "stacking": { "mode": "normal" }, "lineWidth": 1, "showPoints": "never" },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 27 },
      "id": 20,
      "options": { "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Pipeline Stage Duration (avg)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(pipeline_duration_seconds_sum{job=\"fieldnotes_worker\"}[$__rate_interval]) / rate(pipeline_duration_seconds_count{job=\"fieldnotes_worker\"}[$__rate_interval])",
          "legendFormat": "{{stage}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "scheme", "schemeType": "BuGn" },
          "custom": { "fillOpacity": 100, "hideFrom": { "legend": false, "tooltip": false, "viz": false }, "scaleDistribution": { "type": "log", "log": 2 } },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 27 },
      "id": 21,
      "options": { "calculate": true, "cellGap": 1, "color": { "exponent": 0.5, "fill": "dark-orange", "mode": "scheme", "reverse": false, "scale": "exponential", "scheme": "BuGn", "steps": 64 }, "filterValues": { "le": 1e-9 }, "tooltip": { "show": true, "yHistogram": true }, "yAxis": { "unit": "s" } },
      "title": "Total Document Processing Time (heatmap)",
      "type": "heatmap",
      "targets": [
        {
          "expr": "sum(increase(pipeline_total_duration_seconds_bucket{job=\"fieldnotes_worker\"}[$__rate_interval])) by (le)",
          "legendFormat": "{{le}}",
          "format": "heatmap",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
