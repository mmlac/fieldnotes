      "title": "Pipeline Throughput",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 30, "stacking": { "mode": "normal" }, "lineWidth": 1, "showPoints": "never" },
          "unit": "opm"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 10,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Documents Processed / min",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(documents_processed_total{job=\"fieldnotes_worker\", source_type=~\"$source_type\"}[$__rate_interval])) by (source_type) * 60",
          "legendFormat": "{{source_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
